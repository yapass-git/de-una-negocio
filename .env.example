# Base URL of the deuna-api realtime backend.
# Leave unset to use the deployed Fly.io backend (default).
# Override to point at a local backend:
# NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=https://deuna-api-marcado993.fly.dev

# Shared access code that unlocks the admin console (AdminAccessGate).
# Shopkeepers type it or scan it from the QR on the login screen.
# Defaults to "2026" when unset; override in production.
# NEXT_PUBLIC_ADMIN_CODE=2026
